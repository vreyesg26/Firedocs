        {
          "key": "Instalar JARs",
          "value": "QA: GetExtraFundingRegional.jarPRD: GetExtraFundingRegional.jar"
        },
        {
          "key": "Base de Datos",
          "value": "feature/kevin.castillo_TPCDG-35_TPCDG-78_TPCDG-529"
        },
        {
          "key": "Ejecutar scripts",
          "value": "QA:INSERT_MWSERVICES.sql PRD: INSERT_MWSERVICES.sql"
        },
        {
          "key": "BD",
          "value": "DYNAMOEsquema: MWSERVICES"
        },
        {
          "key": "Instalar JAR’s",
          "value": "QA: 1. ActualizacionClienteTarjetaCreditoNI.jar 2. CalculaFinanciamientoTC.jar 3. SolicitaFinanciamientoTC.jar PRD: 1. ActualizacionClienteTarjetaCreditoNI.jar 2. CalculaFinanciamientoTC.jar 3. SolicitaFinanciamientoTC.jar"
        },
        {
          "key": "N/A",
