{
  "productName": "Firedocs",
  "appId": "com.vrdev.installation-manuals-generator",
  "files": ["dist-electron", "dist-react"],
  "extraResources": [
    {
      "from": "vendor/portable-git/windows",
      "to": "git/windows",
      "filter": ["**/*"]
    }
  ],
  "icon": "./src/ui/assets/firedocs-logo.png",
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility"
  },
  "win": {
    "target": [{ "target": "zip", "arch": ["x64"] }]
  },
  "artifactName": "Firedocs.${ext}"
}
